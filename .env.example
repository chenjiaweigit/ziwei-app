# 复制为 .env.local 后填入实际值

# ─── AI 推理（OpenAI 兼容协议，无感多服务容灾）───
# 依次配置主/备 AI 服务，失败时自动切换到下一个 slot
# PRIMARY 必填，PROVIDER1/PROVIDER2 可选，不使用的留空即可
#
# 切换顺序: PRIMARY → PROVIDER1 → PROVIDER2
# 每个 slot 内按 AI_RETRY_COUNT 重试，全部失败才切到下一个

# 主服务
PRIMARY_PROVIDER=deepseek
PRIMARY_BASE_URL=https://api.deepseek.com/v1
PRIMARY_API_KEY=sk-your-deepseek-key
PRIMARY_MODEL=deepseek-chat
PRIMARY_RETRY_COUNT=1

# 备服务 1（可选）
# PROVIDER1_PROVIDER=openrouter
# PROVIDER1_BASE_URL=https://openrouter.ai/api/v1
# PROVIDER1_API_KEY=sk-or-v1-xxx
# PROVIDER1_MODEL=openai/gpt-oss-120b:free
# PROVIDER1_RETRY_COUNT=1

# 备服务 2（可选）
# PROVIDER2_PROVIDER=...
# PROVIDER2_BASE_URL=...
# PROVIDER2_API_KEY=...
# PROVIDER2_MODEL=...
# PROVIDER2_RETRY_COUNT=1

# ─── 旧版变量（已弃用，迁移至上方 PRIMARY_* / PROVIDER1_*）───
# 若未配置新变量且旧变量存在，自动兼容映射：
#   AI_PROVIDER + DEEPSEEK_API_KEY + AI_MODEL → PRIMARY
#   MIMO_API_KEY + MIMO_BASE_URL              → PROVIDER1
# AI_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-xxx
# MIMO_API_KEY=sk-xxx
# MIMO_BASE_URL=https://...
# AI_MODEL=...

# ─── 站点 ───
NEXT_PUBLIC_SITE_URL=http://localhost:3000
